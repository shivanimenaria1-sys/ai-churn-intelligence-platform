# =============================================================================
# B2B Churn Predictor — Git ignore rules
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.eggs/
dist/
build/
pip-wheel-metadata/
*.manifest
*.spec

# --- Virtual environments ---
.venv/
venv/
env/
ENV/
.python-version

# --- Jupyter / IPython ---
.ipynb_checkpoints/
**/.ipynb_checkpoints/
*.nbconvert.ipynb
profile_default/
ipython_config.py

# --- Testing & type checkers ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# --- Environment & secrets ---
.env
.env.*
!.env.example
*.pem
secrets/

# --- Data (keep structure, exclude large raw files) ---
#data/*.csv
data/*.parquet
data/*.xlsx
data/*.feather
!data/.gitkeep
!data/README.md

# --- Model artifacts (regenerate via notebooks) ---
models/**/*.joblib
models/**/*.pkl
models/**/*.pickle
models/**/*.h5
models/**/*.onnx
!models/.gitkeep
!models/**/.gitkeep
!models/README.md
!models/churn_xgboost_model.joblib
!models/artifacts/churn_preprocessor.joblib
!models/artifacts/feature_names.joblib

# --- Logs & runtime ---
*.log
logs/
*.pid
.Dash_*

# --- OS ---
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# --- IDEs & editors ---
.idea/
.vscode/
*.swp
*.swo
*~
.cursor/

# --- Packaging ---
*.tar.gz
*.zip
